{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=strideflow;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "StrideFlow",
    "Audience": "StrideFlow.Client",
    "Key": "strideflow-development-signing-key-change-me-1234567890",
    "AccessTokenLifetimeMinutes": 20,
    "RefreshTokenLifetimeDays": 30
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "strideflow"
  },
